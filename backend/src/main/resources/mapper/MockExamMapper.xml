<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hnust.examai.module.mock.MockExamMapper">

    <!-- 查询用户历史模考（已完成和超时，按开始时间倒序） -->
    <select id="selectHistoryByUserId" resultType="com.hnust.examai.entity.MockExam">
        SELECT *
        FROM t_mock_exam
        WHERE user_id = #{userId}
          AND status IN (1, 2)
        ORDER BY started_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

</mapper>
